# ─── Required ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Email sending (choose ONE provider, leave others blank) ──────────────────

# Option A: Brevo (recommended)
BREVO_API_KEY=
BREVO_FROM=noreply@yourdomain.com

# Option B: Resend
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.com

# Option C: SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@yourdomain.com

# Option D: Gmail SMTP (dev/testing only)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
