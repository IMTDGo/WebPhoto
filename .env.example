# MongoDB Atlas connection string
# 格式: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/webphoto?retryWrites=true&w=majority

# Server port (optional, default 3000)
PORT=3000

# R2 storage settings (Cloudflare R2 bucket)
# R2_BUCKET_NAME: your R2 bucket name (e.g., test-1)
# R2_ACCOUNT_ID: Cloudflare Account ID
# R2_API_TOKEN: API token with R2 "Object Read & Write" permission
# R2_BUCKET_URL: Public development URL of your bucket (e.g., https://pub-xxxxxx.r2.dev)
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_BUCKET_URL=
